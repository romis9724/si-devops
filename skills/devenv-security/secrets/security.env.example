# 실제 파일: ${DEVENV_HOME}/secrets/security.env (chmod 600)
# preset.json에는 *_ref 키만 두고, 평문 비밀값은 이 파일에만 둡니다.
# 생성: cp devenv-security/secrets/security.env.example "${DEVENV_HOME}/secrets/security.env"

SONAR_ADMIN_PASSWORD=changeme
SONAR_NEW_ADMIN_PASSWORD=changeme!1
JENKINS_TOKEN=
# NVD_API_KEY=   # 선택 — Dependency-Check (preset dependency_check.nvd_api_key_ref 와 매칭)
