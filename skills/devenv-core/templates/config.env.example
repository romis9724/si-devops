# ============================================================
# devenv-core config.env — 예시 파일 (Example)
# 실제 파일은 스킬 PHASE 7에서 generate-configs.sh 실행 시 자동 생성됩니다.
# DO NOT COMMIT 실제 파일 — secrets 포함
# ============================================================

# ----- 프로젝트 / 인프라 -----
PROJECT_NAME="myproject"            # 영소문자·숫자·하이픈만 허용
OS_TYPE="ubuntu22"                  # ubuntu22 | ubuntu20 | debian11
COMPOSE_MODE="single"               # single | multi
INTERNAL_NETWORK="10.0.1.0/24"      # 호스트와 충돌하지 않는 대역 선택
DOMAIN=""                           # FQDN (없으면 빈값; self-signed 인증서는 localhost CN으로 생성)
TIMEZONE="Asia/Seoul"               # TZ database 이름

# ----- 접근 보안 -----
SSL_TYPE="self-signed"              # none | self-signed | letsencrypt | public
                                    # 기본 self-signed: ssl-init.sh가 자동 인증서 생성
                                    # 빈 값/미정의 시에도 self-signed로 자동 승격
SSL_CONTACT_EMAIL=""                # letsencrypt 발급 시 필수 (예 "ops@example.com")
SSH_VIA_BASTION="y"                 # y | n
TEAM_SIZE="5"                       # 동시 사용 예상 인원 (Jenkins executor 수 참고)

# ----- 서버 IP (4개, single 모드는 동일 호스트) -----
BASTION_IP="10.0.1.10"
GITLAB_IP="10.0.1.11"
NEXUS_IP="10.0.1.12"
JENKINS_IP="10.0.1.13"

# ----- 자격증명 (PHASE 5 공통 1회 입력) -----
# 아래 비밀번호는 GitLab root / Jenkins admin / Nexus admin 공통으로 사용됩니다.
# 12자 이상, 영대소문자+숫자+특수문자 조합 권장.
ADMIN_SHARED_PASSWORD=""            # 반드시 입력 (빈값이면 PHASE 5에서 인터랙티브 입력)

JENKINS_ADMIN_USER="admin"
JENKINS_ADMIN_PASSWORD=""           # PHASE 8 post-install이 자동 채움

GITLAB_ROOT_PASSWORD=""             # PHASE 8 post-install이 자동 채움
GITLAB_ROOT_EMAIL="admin@example.local"

NEXUS_ADMIN_PASSWORD=""             # PHASE 8 post-install이 자동 채움

# ----- 자원 한도 (선택, override 가능) -----
# 프로파일별 기본 mem_limit (호스트 RAM 기준 권장):
#   lean     : GitLab 2g / Nexus 1g / Jenkins 768m / Bastion 128m  (16GB 호스트)
#   standard : GitLab 4g / Nexus 2g / Jenkins 1g   / Bastion 256m  (24GB 호스트, 기본)
#   heavy    : GitLab 6g / Nexus 3g / Jenkins 2g   / Bastion 512m  (32GB+ 호스트)
MEM_BUDGET_PROFILE="standard"       # lean | standard | heavy
GITLAB_MEM_LIMIT=""                 # 직접 override (예 "3g"). 빈값이면 profile 기준
NEXUS_MEM_LIMIT=""
JENKINS_MEM_LIMIT=""
BASTION_MEM_LIMIT=""

# ----- 고정 버전 (검증된 기본값, 변경 시 호환성 확인 필요) -----
GITLAB_VERSION="17.11.7-ce.0"
NEXUS_VERSION="3.78.2"

# ----- post-install이 채우는 값 (PHASE 9 이후 자동 갱신) -----
GITLAB_TOKEN=""                     # PAT (api scope), post-install 단계에서 자동 발급
